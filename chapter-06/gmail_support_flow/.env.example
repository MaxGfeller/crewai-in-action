MODEL=gpt-5.4
OPENAI_API_KEY=sk-...

# Provider mode: fake lets the example run with zero external credentials.
PROVIDERS_MODE=fake

# Real-mode Gmail (leave blank in fake mode)
GOOGLE_CREDENTIALS_JSON=
GMAIL_USER_EMAIL=
GMAIL_LABEL=book-support-demo

# Real-mode Slack (leave blank in fake mode)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#support-escalations

# Customer 360 + KB service (see ../support-service).
# Start it in another terminal BEFORE running the Flow.
SUPPORT_SERVICE_URL=http://127.0.0.1:8077

# Flow persistence for @persist / `uv run replay`.
FLOW_PERSIST_DB_PATH=artifacts/flow_state.sqlite
